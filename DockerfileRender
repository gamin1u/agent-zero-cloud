# Fixed Dockerfile for Render deployment - includes browser_use
FROM python:3.11-slim

# Set working directory
WORKDIR /app

# Install system dependencies for whisper, browser_use and other packages
RUN apt-get update && apt-get install -y \
    git \
    curl \
    wget \
    build-essential \
    libssl-dev \
    libffi-dev \
    python3-dev \
    ffmpeg \
    libsndfile1 \
    # browser_use dependencies
    libnss3 \
    libnspr4 \
    libatk1.0-0 \
    libatk-bridge2.0-0 \
    libcups2 \
    libdrm2 \
    libdbus-1-3 \
    libxkbcommon0 \
    libxcomposite1 \
    libxdamage1 \
    libxfixes3 \
    libxrandr2 \
    libgbm1 \
    libasound2 \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements first for better caching
COPY requirements.txt /app/

# Install critical Python packages explicitly (no silent failures)
RUN pip install --no-cache-dir \
    GitPython \
    openai-whisper \
    cryptography \
    fastapi \
    uvicorn \
    python-multipart \
    python-dotenv \
    requests \
    nest_asyncio \
    openai \
    anthropic \
    litellm \
    langchain-core \
    langchain \
    langchain-community \
    tiktoken \
    pydantic \
    pydantic-settings \
    webcolors \
    sentence-transformers \
    browser-use

# Copy application files
COPY . /app/

# Expose port
EXPOSE 80

# Set environment variables
ENV PORT=80
ENV PYTHONUNBUFFERED=1

# Run the application
CMD ["python", "agent.py"]
